generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntryMode {
  live
  minutes
}

enum Visibility {
  public
  private
}

model User {
  id         String   @id @default(uuid())
  googleSub  String   @unique
  email      String   @unique @db.Citext
  name       String?
  pictureUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  topics     Topic[]
  entries    Entry[]  @relation("EntryAuthor")
}

model Topic {
  id        String   @id @default(uuid())
  ownerId   String
  title     String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  entries   Entry[]

  @@index([ownerId, updatedAt])
}

model Entry {
  id          String      @id @default(uuid())
  topicId      String
  createdById  String
  mode         EntryMode
  visibility   Visibility  @default(public)
  content      String      @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  entryDate    DateTime?

  topic        Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdBy    User        @relation("EntryAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([topicId, mode, createdAt])
  @@index([topicId, mode, entryDate])
}
